# Required: Your Supabase database connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# Required: Generate with `openssl rand -base64 32`
AUTH_SECRET=YOUR_AUTH_SECRET

# Required: GitHub OAuth app credentials
AUTH_GITHUB_ID=YOUR_GITHUB_CLIENT_ID
AUTH_GITHUB_SECRET=YOUR_GITHUB_CLIENT_SECRET

# Optional: GitHub token for community features
GITHUB_TOKEN=YOUR_GITHUB_TOKEN

# Required: The public URL of your server (e.g. http://YOUR_VPS_IP:3000)
PUBLIC_URL=http://YOUR_VPS_IP:3000
